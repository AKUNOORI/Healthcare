{
  "datasets": [
    {
      "name": "ccf23aa8",
      "displayName": "Active Class",
      "queryLines": [
        "SELECT ClassID \r\n",
        "FROM classroomsetup \r\n",
        "WHERE ClassEndDateTime > current_timestamp() and ClassActiveStatus = 'Y'"
      ],
      "catalog": "healthcarenew",
      "schema": "silver"
    },
    {
      "name": "9b536811",
      "displayName": "Active Students based on class",
      "queryLines": [
        "SELECT sp.*, cs.ClassID\r\n",
        "FROM studentprofile sp\r\n",
        "JOIN classstudent cs \r\n",
        "  ON sp.StudentProfileID = cs.StudentProfileID\r\n",
        "WHERE cs.ClassID = :parameter"
      ],
      "parameters": [
        {
          "displayName": "ClassID",
          "keyword": "parameter",
          "dataType": "INTEGER",
          "defaultSelection": {
            "values": {
              "dataType": "INTEGER",
              "values": [
                {
                  "value": "214"
                }
              ]
            }
          }
        }
      ],
      "catalog": "healthcarenew",
      "schema": "silver"
    },

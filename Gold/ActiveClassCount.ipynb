   "source": [
    "%sql\n",
    "CREATE OR REPLACE TABLE healthcarenew.gold.ActiveClassCount\n",
    "USING DELTA\n",
    "AS\n",
    "select classid, count(*) as classCount from healthcarenew.silver.classstudent where ClassID = TRY_CAST(:classid AS BIGINT)\n",
    "   OR :classid IS NULL\n",
    "   OR :classid = ''\n",
    "   group by classid"
   ]
  }

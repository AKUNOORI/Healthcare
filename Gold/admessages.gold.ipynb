   "source": [
    "from pyspark.sql.functions import count, col\n",
    "df_count = spark.table(\"healthcareNew.silver.admessages\")\\\n",
    "    .filter(col(\"EnabledFlag\") == \"Y\")\\\n",
    "    .agg(count(\"*\").alias(\"total_count\"))\n",
    "df_count.write.format(\"delta\").mode(\"overwrite\").saveAsTable(\"healthcareNew.gold.admessages\")\n"
   ]
  }
